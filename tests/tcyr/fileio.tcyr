# tests/tcyr/fileio.tcyr — tula file I/O (M1): write/read/mmap round-trips.
include "src/lib.cyr"
include "lib/assert.cyr"

fn bytes_eq(a, b, n): i64 {
    var i = 0;
    while (i < n) {
        if (load8(a + i) != load8(b + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn test_write_read_roundtrip() {
    var shapeA = alloc(16);
    store64(shapeA, 2);
    store64(shapeA + 8, 3);
    var dataA = alloc(48);
    var i = 0;
    while (i < 6) { store64(dataA + i * 8, 1000 + i); i = i + 1; }
    var b = tula_builder_new();
    tula_builder_add(b, "w.q", TULA_DT_F64, shapeA, 2, dataA, 48);
    var buf = tula_builder_finish(b);
    var total = tula_total_len(buf);

    var path = "/tmp/tula_m1_unsigned.tula";
    assert_eq(tula_write_file(path, buf, total), total, "wrote full buffer");

    var r = tula_read_file(path);
    assert(r != 0, "read back opens");
    assert_eq(tula_count(r), 1, "count survives file round-trip");
    var e = tula_entry(r, 0);
    assert(streq(tula_entry_name(e), "w.q"), "name survives");
    assert_eq(tula_entry_data_len(e), 48, "data_len survives");
    assert(bytes_eq(tula_entry_data(r, e), dataA, 48), "data bit-identical from file");
    return 0;
}

fn test_signed_file() {
    var sk = alloc(64);
    var pk = alloc(32);
    var seed = alloc(32);
    var i = 0;
    while (i < 32) { store8(seed + i, (i + 1) & 0xFF); i = i + 1; }
    ed25519_keypair(seed, sk, pk);

    var shape = alloc(8);
    store64(shape, 3);
    var data = alloc(24);
    var j = 0;
    while (j < 3) { store64(data + j * 8, 7 + j); j = j + 1; }
    var b = tula_builder_new();
    tula_builder_add(b, "w", TULA_DT_F64, shape, 1, data, 24);
    var buf = tula_builder_finish_signed(b, sk);
    var total = tula_total_len(buf);

    var path = "/tmp/tula_m1_signed.tula";
    assert_eq(tula_write_file(path, buf, total), total, "wrote signed file");
    var r = tula_read_file(path);
    assert(r != 0, "signed file opens");
    assert_eq(tula_is_signed(r), 64, "signature survives file");
    assert_eq(tula_verify(r, pk), TULA_SIG_OK, "signature verifies from file");
    return 0;
}

fn test_mmap_read() {
    var shape = alloc(8);
    store64(shape, 2);
    var data = alloc(16);
    store64(data, 111);
    store64(data + 8, 222);
    var b = tula_builder_new();
    tula_builder_add(b, "m", TULA_DT_F64, shape, 1, data, 16);
    var buf = tula_builder_finish(b);
    var total = tula_total_len(buf);
    var path = "/tmp/tula_m1_mmap.tula";
    tula_write_file(path, buf, total);

    var r = tula_open_mmap(path);
    assert(r != 0, "mmap opens");
    assert_eq(tula_count(r), 1, "mmap count");
    var e = tula_entry(r, 0);
    assert(streq(tula_entry_name(e), "m"), "mmap name");
    assert_eq(load64(tula_entry_data(r, e)), 111, "mmap data[0]");
    assert_eq(load64(tula_entry_data(r, e) + 8), 222, "mmap data[1]");
    tula_close_mmap(r);
    return 0;
}

fn test_missing_file() {
    assert_eq(tula_read_file("/tmp/tula_does_not_exist_xyz123.tula"), 0, "missing file -> 0");
    return 0;
}

fn main(): i64 {
    alloc_init();
    test_write_read_roundtrip();
    test_signed_file();
    test_mmap_read();
    test_missing_file();
    return assert_summary();
}

var rc = main();
syscall(60, rc);
