*.iml

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*

# Cyrius build
/build/

# lib/ is populated by `cyrius deps` from cyrius.cyml [deps].stdlib — a
# build artifact, not source. Never commit; never replace with a symlink
# to a cyrius checkout (it causes cross-repo writes when an agent edits
# lib/*.cyr).
/lib/

# Cyrius dep lockfile — regenerated by `cyrius deps` from cyrius.cyml. With the
# [deps.sigil] git+path resolution it can pin local commit hashes CI can't
# fetch; CI re-resolves fresh from the manifest each run. Gitignored (mirrors
# libro, the other sigil consumer).
/cyrius.lock

# Coverage
*.profraw
coverage/
